# =============================================================================
# Paperless NGX - Recommended Configuration
# =============================================================================
# These settings are applied by install.sh on top of the community script
# defaults. The community script already provides: PAPERLESS_DBHOST,
# PAPERLESS_DBPASS, PAPERLESS_SECRET_KEY, PAPERLESS_DATA_DIR,
# PAPERLESS_MEDIA_ROOT, etc.
#
# This file is a REFERENCE. Do not copy it directly over the existing
# paperless.conf - use install.sh which merges these settings safely.
# =============================================================================

# ---- Paths ----
# Ensure the consumer watches the correct directory
PAPERLESS_CONSUMPTION_DIR=/opt/paperless_data/consume

# ---- OCR ----
# Language for OCR processing (install matching tesseract-ocr-<lang> package)
# Common codes: eng, nld, fra, deu, spa
# Multiple languages: eng+nld
PAPERLESS_OCR_LANGUAGE=nld

# ---- Document Organization ----
# Filename format using Jinja2 syntax (NOT the old {var} syntax)
PAPERLESS_FILENAME_FORMAT={{ created_year }}/{{ correspondent }}/{{ title }}

# ---- Consumer ----
# Process files in subdirectories of the consume folder
PAPERLESS_CONSUMER_RECURSIVE=true
# Use subdirectory names as tags
PAPERLESS_CONSUMER_SUBDIRS_AS_TAGS=true
# Automatically delete duplicate files from the consume folder
PAPERLESS_CONSUMER_DELETE_DUPLICATES=true

# ---- SSO / OpenID Connect (e.g. PocketID) ----
# PAPERLESS_APPS=allauth.socialaccount.providers.openid_connect
# PAPERLESS_SOCIALACCOUNT_PROVIDERS={"openid_connect":{"APPS":[{"provider_id":"pocketid","name":"PocketID","client_id":"YOUR_CLIENT_ID","secret":"YOUR_CLIENT_SECRET","settings":{"server_url":"https://pocketid.yourdomain.com/.well-known/openid-configuration"}}]}}
# PAPERLESS_SOCIAL_AUTO_SIGNUP=true

# ---- Document Conversion (Tika + Gotenberg) ----
# Enable to support Office documents (.docx, .xlsx, .odt, .pptx, etc.)
PAPERLESS_TIKA_ENABLED=true
PAPERLESS_TIKA_GOTENBERG_ENDPOINT=http://localhost:3000
PAPERLESS_TIKA_ENDPOINT=http://localhost:9998

# ---- Reverse Proxy (uncomment if using Traefik/nginx/etc.) ----
# PAPERLESS_URL=https://paperless.yourdomain.com
