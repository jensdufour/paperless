# Paperless NGX + OneDrive Sync Configuration
# Copy this file to .env and fill in the values
# These are used by the sync, backup, and FTP scripts (not by Paperless itself,
# which is managed by the Proxmox community script).

# =============================================================================
# Paperless Paths (set by the community script, change only if customized)
# =============================================================================
PAPERLESS_CONSUME=/opt/paperless/consume
PAPERLESS_MEDIA=/opt/paperless/media
PAPERLESS_DATA=/opt/paperless/data

# =============================================================================
# OneDrive Sync
# =============================================================================
# rclone remote name (as configured with "rclone config")
RCLONE_REMOTE=onedrive

# OneDrive folder paths (under My Files > Documents > Paperless)
# Processed/archived documents are synced here
ONEDRIVE_ARCHIVE=Documents/Paperless/Archive
# Phone scans are picked up from here
ONEDRIVE_SCAN=Documents/Paperless/Scan
# Backups are uploaded here
ONEDRIVE_BACKUPS=Documents/Paperless/Backups

# =============================================================================
# FTP (for Canon ImageRunner 1133a scanner)
# =============================================================================
FTP_USER=scanner
FTP_PASSWORD=CHANGE_ME
