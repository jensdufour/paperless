# Paperless NGX + OneDrive Sync Configuration
# Copy this file to .env and fill in the values
# These are used by the sync and backup scripts (not by Paperless itself,
# which is managed by the Proxmox community script).

# =============================================================================
# Paperless Paths (set by the community script, change only if customized)
# =============================================================================
PAPERLESS_CONSUME=/opt/paperless_data/consume
PAPERLESS_MEDIA=/opt/paperless_data/media
PAPERLESS_DATA=/opt/paperless_data/data

# =============================================================================
# OneDrive Sync
# =============================================================================
# rclone remote name (as configured with "rclone config")
RCLONE_REMOTE=onedrive

# OneDrive folder paths (under My Files > Documents > Paperless)
# Processed/archived documents are synced here
ONEDRIVE_ARCHIVE=Documents/Paperless/Archive
# Phone scans are picked up from here
ONEDRIVE_SCAN=Documents/Paperless/Scan
# Backups are uploaded here
ONEDRIVE_BACKUPS=Documents/Paperless/Backups

# =============================================================================
# Paperless Configuration (applied to /opt/paperless/paperless.conf)
# =============================================================================
# OCR language (must match an installed tesseract-ocr-<lang> package)
# Common: eng, nld, fra, deu, spa. Multiple: nld+eng+fra
PAPERLESS_OCR_LANGUAGE=nld+eng+fra

# Filename format (Jinja2 syntax)
PAPERLESS_FILENAME_FORMAT={{ created_year }}/{{ correspondent }}/{{ title }}

# =============================================================================
# Reverse Proxy (optional, required if using Traefik/nginx/etc.)
# =============================================================================
# External URL for Paperless (fixes CSRF errors behind a reverse proxy)
# Leave empty if accessing Paperless directly by IP
PAPERLESS_URL=

# =============================================================================
# SSO / OpenID Connect (optional, e.g. PocketID)
# =============================================================================
# Leave all three empty to disable OIDC login
POCKETID_URL=
POCKETID_CLIENT_ID=
POCKETID_CLIENT_SECRET=
# Automatically create a Paperless account on first OIDC login
PAPERLESS_SOCIAL_AUTO_SIGNUP=true
